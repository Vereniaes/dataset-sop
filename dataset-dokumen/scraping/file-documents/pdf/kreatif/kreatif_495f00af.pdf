	<h3>Vol 6, No 2 (2025): Desember 2025</h3>
		<div id="issueDescription"></div>
		<h3>Table of Contents</h3>
	<h4 class="tocSectionTitle">Articles</h4>
		
				
				
				
<table class="tocArticle">
<tr valign="top">
	<td class="tocArticleCoverImage">
			</td>

	

	<td class="tocArticleTitleAuthors">
		<div class="tocTitle">
							<a href="https://jurnal.dharmawangsa.ac.id/index.php/syntax/article/view/7802">PENERAPAN KADAR PH AIR BERSIH DENGAN METODE REGRESI LINEAR BERBASIS ANDROID</a>
				                                <div>
                <div class="tocDoi">
                <span><img src="https://proceeding.dharmawangsa.ac.id/public/icon-doi-1.png" alt="" /> DOI : <a href="http://dx.doi.org/10.46576/syntax.v6i2.7802">10.46576/syntax.v6i2.7802</a></span>
                                  | <img src="https://proceeding.dharmawangsa.ac.id/public/icon-graph.png" alt="" /> Abstract views : 60 times<br>
                				
                                </div>
